{
  "expo": {
    "name": "MindPulse",
    "slug": "mindpulse",
    "scheme": "mindpulse",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "jsEngine": "hermes",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "MindPulse uses your location to show local weather and air quality.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.daemonberg.mindpulse"
    },
    "android": {
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ],
      "package": "com.daemonberg.mindpulse"
    },
    "extra": {
      "eas": {
        "projectId": "9dc58f8d-ce89-4d49-9bc0-258c81ff8e3f"
      }
    },
    "plugins": [
      "expo-font",
      [
        "react-native-ble-plx",
        {
          "bluetoothAlwaysPermission": "MindPulse uses Bluetooth to connect to your ESP32 prototype."
        }
      ]
    ]
  }
}
